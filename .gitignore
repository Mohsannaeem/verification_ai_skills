# gitignore template for LangChain products, e.g., LangGraph, LangSmith
# website: https://www.langchain.com/
# website: https://www.langchain.com/langgraph

# LangGraph
.langgraph_api/

# Python cache
__pycache__/
*.pyc
*.pyo

# Tool / runtime caches
.cache/
vector_db/

# Simulation run outputs
run/

# Generated VIP testbench output
Output/

# QuestaSim / VCS compiled library artifacts
*.qdb
*.qpg
*.qtl
*.tfdb
*.log

# Intermediate generated files
json/
markdown/

# Generated verification reports (use examples/ for committed reference outputs)
verf_plan_reports/

# Temp / log files
startup_err.txt

# Misnamed output directories
VerificationVERIFICATION_PLANNEROutputaxi_stream_master_vip_tb/
